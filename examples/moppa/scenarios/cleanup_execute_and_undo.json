{
  "scenario_id": "cleanup_execute_and_undo",
  "description": "Preview, confirm, execute, list undoable actions, and undo the resulting cleanup batch.",
  "destructive": true,
  "tags": ["cleanup", "undo", "destructive"],
  "turns": [
    {
      "user": "Preview the first cleanup unit",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": [
            "Preview for",
            "Exact current match count:",
            "Nothing has changed yet.",
            "Undo will be available after execution."
          ]
        },
        {
          "type": "tool_used",
          "values": ["cleanup"]
        },
        {
          "type": "tool_call_matches",
          "tool": "cleanup",
          "arguments": {
            "dry_run": true
          }
        }
      ]
    },
    {
      "user": "do it",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": [
            "Ready to apply",
            "Undo will be available after execution.",
            "Reply `confirm` to proceed."
          ]
        },
        {
          "type": "tool_used",
          "values": ["cleanup"]
        }
      ]
    },
    {
      "user": "confirm",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": [
            "ran successfully",
            "Undo is available for batch",
            "Say `undo that`"
          ]
        },
        {
          "type": "tool_used",
          "values": ["cleanup"]
        },
        {
          "type": "tool_call_matches",
          "tool": "cleanup",
          "arguments": {
            "confirmed": true
          }
        }
      ]
    },
    {
      "user": "what can I undo",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": [
            "Here are the most recent cleanup batches you can still undo:",
            "undo last 2 actions"
          ]
        }
      ]
    },
    {
      "user": "undo that",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": [
            "Undid the latest cleanup batch",
            "Restored **"
          ]
        },
        {
          "type": "tool_used",
          "values": ["undo_batch"]
        }
      ]
    }
  ]
}
