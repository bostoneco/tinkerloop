{
  "scenario_id": "send_first_time_setup_and_send",
  "description": "First outbound send asks for one-time identity setup, then confirms and sends.",
  "destructive": true,
  "tags": ["send", "compose", "outbound"],
  "turns": [
    {
      "user": "Send an email to bostone@gmail.com with subject \"Tinkerloop Send Test One\" and body \"This is a Tinkerloop send test.\"",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": ["connected Gmail account", "Say `no name`"]
        },
        {
          "type": "tool_used",
          "values": ["compose"]
        },
        {
          "type": "tool_call_matches",
          "tool": "compose",
          "arguments": {"mode": "send", "to": "bostone@gmail.com"}
        }
      ]
    },
    {
      "user": "no name",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": ["Ready to send from", "Confirm to send."]
        },
        {
          "type": "tool_used",
          "values": ["remember", "send_email"]
        }
      ]
    },
    {
      "user": "confirm",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": ["Email sent to bostone@gmail.com", "from `"]
        },
        {
          "type": "tool_used",
          "values": ["send_email"]
        },
        {
          "type": "tool_call_matches",
          "tool": "send_email",
          "arguments": {"confirmed": true}
        }
      ]
    }
  ]
}
