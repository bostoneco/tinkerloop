{
  "scenario_id": "send_reuse_saved_identity",
  "description": "After initial setup, outbound send reuses the saved identity and goes straight to confirmation.",
  "destructive": true,
  "tags": [
    "send",
    "compose",
    "outbound"
  ],
  "turns": [
    {
      "user": "Send another email to bostone@gmail.com with subject \"Tinkerloop Send Test Two\" and body \"This is the second Tinkerloop send test.\"",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": [
            "ready to send",
            "confirm to send"
          ]
        },
        {
          "type": "assistant_not_contains",
          "values": [
            "Say `no name`",
            "connected Gmail account"
          ]
        },
        {
          "type": "tool_used",
          "values": [
            "compose"
          ]
        },
        {
          "type": "tool_call_matches",
          "tool": "compose",
          "arguments": {
            "mode": "send",
            "to": "bostone@gmail.com"
          }
        }
      ]
    },
    {
      "user": "confirm",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": [
            "Email sent to bostone@gmail.com",
            "from `"
          ]
        },
        {
          "type": "tool_used",
          "values": [
            "send_email"
          ]
        },
        {
          "type": "tool_call_matches",
          "tool": "send_email",
          "arguments": {
            "confirmed": true
          }
        }
      ]
    }
  ]
}
