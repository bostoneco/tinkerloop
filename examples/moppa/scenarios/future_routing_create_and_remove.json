{
  "scenario_id": "future_routing_create_and_remove",
  "description": "Preview future-routing filters, create them, then remove them again.",
  "destructive": true,
  "tags": ["routing", "destructive", "filters"],
  "turns": [
    {
      "user": "Keep this from piling up again and route future clutter correctly.",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": [
            "I can keep similar clutter out of your inbox going forward by adding Gmail filters like these:",
            "skip Inbox",
            "Nothing has changed yet."
          ]
        }
      ]
    },
    {
      "user": "do it",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": [
            "Ready to create",
            "Reply `confirm` to proceed."
          ]
        }
      ]
    },
    {
      "user": "confirm",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": [
            "Created **",
            "If you want them removed, say `remove those filters`."
          ]
        },
        {
          "type": "tool_used",
          "values": ["create_gmail_filter"]
        }
      ]
    },
    {
      "user": "remove those filters",
      "checks": [
        {
          "type": "assistant_contains_all",
          "values": ["Removed **"]
        },
        {
          "type": "tool_used",
          "values": ["manage_filters"]
        }
      ]
    }
  ]
}
